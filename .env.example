# ──────────────────────────────────────────────────────────────
#  Midoriad Transports — Variables d'environnement
#  Copiez ce fichier en « .env.local » et renseignez vos valeurs.
# ──────────────────────────────────────────────────────────────

# Adresse de réception de tous les formulaires (devis, commande, contact, candidature)
CONTACT_EMAIL=midoriadtransports@hotmail.com

# ── Envoi des e-mails (SMTP) ──
# Exemple pour Outlook / Hotmail : smtp-mail.outlook.com (port 587, STARTTLS)
# Conseil : créez un mot de passe d'application dédié.
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=midoriadtransports@hotmail.com
SMTP_PASSWORD=
# Adresse affichée comme expéditeur (souvent identique à SMTP_USER)
SMTP_FROM="Midoriad Transports <midoriadtransports@hotmail.com>"

# URL publique du site (pour le SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://www.midoriad-transports.fr

# Coordonnées publiques affichées sur le site
NEXT_PUBLIC_PHONE=+33 6 00 00 00 00
NEXT_PUBLIC_EMAIL=midoriadtransports@hotmail.com
